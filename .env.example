# =============================================================================
# Mosaic — environment variables (EXAMPLE)
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
#   cp .env.example .env
# Placeholders below are safe defaults for local docker-compose development.
# =============================================================================

# -----------------------------------------------------------------------------
# Local Postgres (read by docker-compose.yml)
# -----------------------------------------------------------------------------
POSTGRES_USER=mosaic
POSTGRES_PASSWORD=mosaic
POSTGRES_DB=mosaic
# Host port the DB is published on. Change if 5432 is taken locally.
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Backend API (services/api) — read via pydantic-settings
# -----------------------------------------------------------------------------
# SQLAlchemy URL. Must match the Postgres settings above for local dev.
# Uses the psycopg (v3) driver. Format:
#   postgresql+psycopg://USER:PASSWORD@HOST:PORT/DBNAME
# For hosted Postgres later (Supabase/Neon), replace this whole value with the
# provider's connection string (keep the `+psycopg` driver prefix) and you're done.
DATABASE_URL=postgresql+psycopg://mosaic:mosaic@localhost:5432/mosaic

# APP connection — the NON-superuser `mosaic_app` role the API runs as, so
# Postgres row-level security is actually enforced (the admin `mosaic` role is a
# superuser and bypasses RLS). Created by migration 0008. REQUIRED for the API;
# there is no fallback to DATABASE_URL. Rotate the password for any real deploy.
APP_DATABASE_URL=postgresql+psycopg://mosaic_app:mosaic_app@localhost:5432/mosaic

# Comma-separated list of browser origins allowed to call the API (CORS).
CORS_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Frontend (apps/web) — Next.js public vars must be prefixed NEXT_PUBLIC_
# Put these in apps/web/.env.local for the web app to read them.
# -----------------------------------------------------------------------------
# Base URL the browser uses to reach the FastAPI backend.
NEXT_PUBLIC_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# SEC EDGAR — required contact string sent as the User-Agent on every request.
# SEC blocks requests without a real contact. Read by the ingestion code.
# Format: "AppName purpose your-email@example.com"
# -----------------------------------------------------------------------------
SEC_USER_AGENT=Mosaic research you@example.com

# -----------------------------------------------------------------------------
# Milestone 3 — RAG ("Ask this filing")
# -----------------------------------------------------------------------------
# Local embedding model (sentence-transformers). 384-dim; locked into migration
# 0004 — changing it requires a re-embed + new migration.
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# LLM for grounded answers. `gemini` = Google AI Studio (free tier). `mock` is a
# deterministic offline provider for tests / no-key local poking.
LLM_PROVIDER=gemini
# Model must be one your key actually serves (list them with the SDK's
# client.models.list()). gemini-2.5-flash-lite is verified working here; the
# older gemini-2.0-flash returns a limit:0 quota error on this project. Free tier
# is ~20 requests/day per model — answer_cache absorbs repeats.
LLM_MODEL=gemini-2.5-flash-lite
# Free key: https://aistudio.google.com/apikey  (leave blank to use LLM_PROVIDER=mock)
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Auth (Milestone 4a) — JWT session cookies
# -----------------------------------------------------------------------------
# Secret used to sign session JWTs. MUST be a long random value in any non-local
# environment (e.g. `python -c "import secrets; print(secrets.token_urlsafe(48))"`).
AUTH_SECRET_KEY=dev-insecure-change-me
# Set true behind HTTPS in production; false lets the cookie work on http://localhost.
AUTH_COOKIE_SECURE=false
